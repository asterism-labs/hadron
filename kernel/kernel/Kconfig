# Hadron kernel core configuration.

menu "General"

config serial_log
    bool "Enable serial port logging"
    default y
    binding cfg

config LOG_LEVEL
    choice "Kernel log level" [error, warn, info, debug, trace]
    default "debug"
    binding cfg cumulative
    binding const

config KERNEL_HEAP_SIZE
    u64 "Kernel heap size in bytes"
    default 0x100000
    binding const

endmenu

menu "Processor"

config acpi
    bool "ACPI table parsing and platform device discovery"
    default y
    binding cfg
    help "Parse ACPI tables (MADT, HPET, MCFG) for interrupt routing, timers, and PCI ECAM"

config apic
    bool "APIC interrupt controller (auto-selected by SMP)"
    default n
    depends on acpi
    binding cfg
    help "Advanced interrupt controller. Requires ACPI MADT. Auto-selected by SMP."

config smp
    bool "Enable symmetric multiprocessing"
    default y
    depends on acpi
    select apic
    binding cfg
    binding build
    help "Boot application processors and enable per-CPU scheduling"

config MAX_CPUS
    u32 "Maximum number of CPUs supported"
    default 256
    range 1 256
    depends on smp
    binding const

config alt_instructions
    bool "Enable alternative-instruction patching"
    default y
    binding cfg
    help "Detect CPU features via CPUID at boot and patch function pointers to optimized implementations"

config kernel_fpu
    bool "Enable kernel FPU/SIMD usage"
    default y
    depends on alt_instructions
    binding cfg
    help "Allow the kernel to use SSE/AVX registers for bulk memory operations via KernelFpuGuard"

endmenu

menu "Platform"

config pci
    bool "PCI/PCIe bus support"
    default y
    binding cfg
    binding build
    help "PCI bus enumeration, ECAM, and driver matching. Disabling removes all PCI drivers."

menu "Interrupt Controllers"

    config pic_legacy
        bool "Legacy PIC interrupt delivery"
        default y
        binding cfg
        help "Use 8259 PIC for interrupt routing when APIC is unavailable. Required for non-ACPI configs."

endmenu

menu "Timers"

    config hpet
        bool "HPET (High Precision Event Timer)"
        default y
        depends on acpi
        binding cfg
        help "High-resolution timer discovered via ACPI HPET table. Preferred clock source."

    config pit_timer
        bool "PIT periodic timer (legacy system timer)"
        default y
        binding cfg
        help "8254 PIT channel 0 as system timer. Fallback when HPET is unavailable."

endmenu

endmenu

menu "Debugging"

config lock_debug
    bool "IRQ-context spinlock assertion"
    default y
    binding cfg

config lockdep
    bool "Lock dependency tracking"
    default y
    binding cfg

config lockdep_warn
    bool "Lockdep warn-only mode (log violations, do not panic)"
    default y
    depends on lockdep
    binding cfg

config no_work_steal
    bool "Disable work stealing (debug)"
    default n
    depends on smp
    binding cfg
    help "Force tasks to run on the CPU they were spawned on"

config lock_stress
    bool "Lock contention stress delays"
    default n
    depends on lockdep
    binding cfg
    help "Inject random spin delays around lock acquire/release to surface race conditions"

config LOCK_STRESS_MAX_US
    u32 "Maximum stress delay (microseconds)"
    default 10
    range 1 100
    depends on lock_stress
    binding const

config lock_stat
    bool "Lock contention statistics"
    default n
    depends on lockdep
    binding cfg
    help "Track per-lock contention counts and hold times"

endmenu

menu "Tracing"

config trace_mm
    bool "Memory management tracing (PMM, VMM, heap)"
    default n
    binding cfg

config trace_vfs
    bool "VFS tracing"
    default n
    binding cfg

config trace_sched
    bool "Scheduler tracing"
    default n
    binding cfg

config trace_pci
    bool "PCI bus tracing"
    default n
    binding cfg

config trace_acpi
    bool "ACPI tracing"
    default n
    binding cfg

config trace_irq
    bool "Interrupt tracing"
    default n
    binding cfg

config trace_syscall
    bool "Syscall tracing"
    default n
    binding cfg

config trace_drivers
    bool "Driver framework tracing"
    default n
    binding cfg

config trace_net
    bool "Network (AF_UNIX socket) tracing"
    default n
    binding cfg

endmenu

menu "Sanitizers"

config debug_heap_poison
    bool "Heap allocation poisoning & red zones"
    default n
    binding cfg
    help "Fill allocations with 0xCD, freed memory with 0xDD, add 16-byte red zones (0xFD)"

config debug_pmm_poison
    bool "Physical page poisoning"
    default n
    binding cfg
    help "Fill freed pages with 0xDEAD pattern, verify on allocation (detects use-after-free)"

config debug_alloc_track
    bool "Allocation origin tracking"
    default n
    depends on debug_heap_poison
    binding cfg
    help "Track allocation counts and origins, provides dump_alloc_stats() for leak investigation"

endmenu

menu "Profiling"

config profile_sample
    bool "Sampling profiler"
    default n
    depends on acpi
    binding cfg

config PROFILE_SAMPLE_RATE
    u32 "Sample rate (Hz, max 1000)"
    default 100
    range 1 1000
    depends on profile_sample
    binding const

config PROFILE_SAMPLE_DEPTH
    u32 "Max stack depth per sample"
    default 16
    range 1 64
    depends on profile_sample
    binding const

config PROFILE_SAMPLE_BUFFER
    u32 "Per-CPU sample buffer entries"
    default 1024
    range 128 16384
    depends on profile_sample
    binding const

config profile_ftrace
    bool "Function tracing (mcount)"
    default n
    binding cfg
    binding build

config PROFILE_FTRACE_BUFFER_KB
    u32 "Per-CPU ftrace buffer (KB)"
    default 64
    range 16 1024
    depends on profile_ftrace
    binding const

config PROFILE_DURATION_SECS
    u32 "Profiling duration (seconds)"
    default 10
    range 1 300
    depends on profile_sample || profile_ftrace
    binding const

endmenu

# ===========================================================================
# Presets
# ===========================================================================

preset debug
    help "Development defaults with full debug aids"
    set serial_log y
    set LOG_LEVEL "debug"
    set pci y
    set hpet y
    set pit_timer y
    set pic_legacy y
    set lock_debug y
    set lockdep y
    set lockdep_warn y

preset release
    help "Production settings, minimal debug overhead"
    set serial_log y
    set LOG_LEVEL "warn"
    set pci y
    set hpet y
    set pit_timer y
    set pic_legacy y
    set lock_debug n
    set lockdep n

preset perf
    inherits debug
    help "Performance testing and profiling"
    set profile_sample y
    set PROFILE_SAMPLE_RATE 100
    set PROFILE_SAMPLE_DEPTH 16
    set PROFILE_SAMPLE_BUFFER 1024
    set PROFILE_DURATION_SECS 10

preset sched_stress
    inherits debug
    help "Scheduler stress testing with SMP"
    set smp y
    set MAX_CPUS 4
    set trace_sched y

preset lock_stress
    inherits debug
    help "Lock contention stress testing"
    set smp y
    set MAX_CPUS 4
    set lock_stress y
    set LOCK_STRESS_MAX_US 10
    set lockdep y
    set lock_debug y
    set lock_stat y

preset sanitizers
    inherits debug
    help "Memory sanitizer debugging"
    set debug_heap_poison y
    set debug_pmm_poison y
    set debug_alloc_track y
    set trace_mm y
